# Environment Variables Template
# Copy this file to .env.local and fill in your actual values

# ========================================
# FORM SUBMISSION
# ========================================
# URL endpoint for contact form submissions (e.g., Formspree, Netlify Forms, custom backend)
NEXT_PUBLIC_GET_FORM_URL=https://formspree.io/f/your-form-id

# ========================================
# SEO & ANALYTICS
# ========================================
# Google Search Console verification code
NEXT_PUBLIC_GOOGLE_VERIFICATION=your-google-verification-code

# Bing Webmaster Tools verification code  
NEXT_PUBLIC_BING_VERIFICATION=your-bing-verification-code

# Google Analytics 4 Measurement ID (optional)
NEXT_PUBLIC_GA_MEASUREMENT_ID=G-XXXXXXXXXX

# ========================================
# EXTERNAL APIS
# ========================================
# If using external APIs for blog, CMS, etc.
# API_URL=your-api-url
# API_KEY=your-api-key

# ========================================
# DEVELOPMENT SETTINGS
# ========================================
# Set to true to enable development features
NODE_ENV=development

# Next.js specific
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=your-nextauth-secret

# ========================================
# DEPLOYMENT
# ========================================
# Production domain (for sitemap generation)
NEXT_PUBLIC_SITE_URL=https://felipevargas.vercel.app